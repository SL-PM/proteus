{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PROTEUS",
  "version": "0.6.0",
  "identifier": "com.slpm.proteus",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "PROTEUS",
        "width": 520,
        "height": 660,
        "minWidth": 420,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
